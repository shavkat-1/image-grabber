<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Image Grabber</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f0f13; color: #e0e0e0; min-height: 100vh; }
        header { background: #1a1a24; border-bottom: 1px solid #2d2d3d; padding: 18px 32px; display: flex; align-items: center; gap: 12px; }
        header h1 { font-size: 1.3rem; font-weight: 600; color: #fff; }
        .logo { width: 32px; height: 32px; background: linear-gradient(135deg, #6c63ff, #3ecfcf); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
        .container { max-width: 960px; margin: 0 auto; padding: 32px 16px; }
        .form-card { background: #1a1a24; border: 1px solid #2d2d3d; border-radius: 14px; padding: 28px 32px; margin-bottom: 36px; }
        .form-card h2 { font-size: .85rem; font-weight: 600; color: #a0a0b8; text-transform: uppercase; letter-spacing: .8px; margin-bottom: 20px; }
        .form-row { display: grid; grid-template-columns: 1fr; gap: 14px; }
        .form-row.two-col { grid-template-columns: 1fr 1fr; }
        label { display: block; font-size: .78rem; color: #8888a0; margin-bottom: 6px; font-weight: 500; }
        input[type="text"], input[type="number"] { width: 100%; background: #13131c; border: 1px solid #2d2d3d; border-radius: 8px; color: #e0e0e0; padding: 10px 14px; font-size: .95rem; outline: none; transition: border-color .2s; }
        input:focus { border-color: #6c63ff; }
        .btn-grab { margin-top: 20px; width: 100%; padding: 12px; background: linear-gradient(135deg, #6c63ff, #3ecfcf); border: none; border-radius: 9px; color: #fff; font-size: 1rem; font-weight: 600; cursor: pointer; transition: opacity .2s; }
        .btn-grab:hover { opacity: .9; }
        .btn-grab:disabled { opacity: .5; cursor: not-allowed; }
        .status { padding: 12px 16px; border-radius: 8px; font-size: .9rem; margin-top: 14px; display: none; }
        .status.info    { background: #1e2a40; border: 1px solid #3a5280; color: #80b0ff; display: block; }
        .status.success { background: #1a3028; border: 1px solid #2d6048; color: #6ed8a0; display: block; }
        .status.error   { background: #3a1a1a; border: 1px solid #6e3030; color: #ff8080; display: block; }
        .gallery-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
        .gallery-header h2 { font-size: 1.1rem; font-weight: 600; color: #fff; }
        .badge { background: #2d2d3d; color: #a0a0b8; font-size: .75rem; padding: 3px 10px; border-radius: 20px; }
        .gallery { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; }
        .gallery-item { border-radius: 10px; overflow: hidden; border: 1px solid #2d2d3d; aspect-ratio: 1; background: #1a1a24; animation: fadeIn .4s ease; }
        .gallery-item img { width: 100%; height: 100%; object-fit: cover; display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: scale(.95); } to { opacity: 1; transform: scale(1); } }
        .empty-state { grid-column: 1/-1; text-align: center; padding: 60px 0; color: #555570; }
        .empty-state .icon { font-size: 3rem; margin-bottom: 12px; }
        .loader { display: inline-flex; gap: 4px; vertical-align: middle; }
        .loader span { width: 7px; height: 7px; background: #fff; border-radius: 50%; animation: bounce .6s infinite alternate; }
        .loader span:nth-child(2) { animation-delay: .15s; }
        .loader span:nth-child(3) { animation-delay: .30s; }
        @keyframes bounce { from { transform: translateY(0); opacity: .5; } to { transform: translateY(-5px); opacity: 1; } }
        @media (max-width: 540px) { .form-row.two-col { grid-template-columns: 1fr; } }
    </style>
</head>
<body>
<header>
    <div class="logo">🖼</div>
    <h1>Image Grabber</h1>
</header>
<div class="container">
    <div class="form-card">
        <h2>Настройки загрузки</h2>
        <div class="form-row">
            <div>
                <label for="url">URL страницы</label>
                <input type="text" id="url" placeholder="https://example.com/gallery">
            </div>
        </div>
        <div class="form-row two-col" style="margin-top:14px;">
            <div>
                <label for="min_width">Мин. ширина (px)</label>
                <input type="number" id="min_width" placeholder="0" min="0" value="0">
            </div>
            <div>
                <label for="min_height">Мин. высота (px)</label>
                <input type="number" id="min_height" placeholder="0" min="0" value="0">
            </div>
        </div>
        <div class="form-row" style="margin-top:14px;">
            <div>
                <label for="text">Текст на картинке</label>
                <input type="text" id="text" placeholder="Ваш текст...">
            </div>
        </div>
        <button class="btn-grab" id="grabBtn" onclick="grabImages()">Загрузить изображения</button>
        <div class="status" id="status"></div>
    </div>
    <div class="gallery-header">
        <h2>Галерея</h2>
        <span class="badge" id="counter">{{ images|length }} фото</span>
    </div>
    <div class="gallery" id="gallery">
        {% if images is empty %}
            <div class="empty-state" id="emptyState">
                <div class="icon">🗂</div>
                <p>Здесь появятся загруженные картинки</p>
            </div>
        {% else %}
            {% for img in images %}
                <div class="gallery-item">
                    <img src="{{ img }}" alt="grabbed image" loading="lazy">
                </div>
            {% endfor %}
        {% endif %}
    </div>
</div>
<script>
async function grabImages() {
    const url       = document.getElementById('url').value.trim();
    const minWidth  = document.getElementById('min_width').value;
    const minHeight = document.getElementById('min_height').value;
    const text      = document.getElementById('text').value.trim();
    const btn       = document.getElementById('grabBtn');

    if (!url) { showStatus('Введите URL страницы', 'error'); return; }

    btn.disabled = true;
    btn.innerHTML = 'Загружаю… <span class="loader"><span></span><span></span><span></span></span>';
    showStatus('Парсим страницу и скачиваем изображения…', 'info');

    try {
        const formData = new FormData();
        formData.append('url',        url);
        formData.append('min_width',  minWidth  || 0);
        formData.append('min_height', minHeight || 0);
        formData.append('text',       text);

        const response = await fetch('/grab', { method: 'POST', body: formData });
        const data = await response.json();

        if (!data.success) throw new Error(data.error || 'Неизвестная ошибка');

        if (data.images.length === 0) {
            showStatus('Картинки не найдены (все отфильтрованы или недоступны)', 'error');
        } else {
            showStatus('✓ Загружено ' + data.count + ' картинок', 'success');
            prependImages(data.images);
        }
    } catch (err) {
        showStatus('Ошибка: ' + err.message, 'error');
    } finally {
        btn.disabled = false;
        btn.textContent = 'Загрузить изображения';
    }
}

function prependImages(paths) {
    const gallery    = document.getElementById('gallery');
    const emptyState = document.getElementById('emptyState');
    const counter    = document.getElementById('counter');
    if (emptyState) emptyState.remove();
    paths.forEach(path => {
        const item = document.createElement('div');
        item.className = 'gallery-item';
        item.innerHTML = '<img src="' + path + '" alt="grabbed image" loading="lazy">';
        gallery.prepend(item);
    });
    counter.textContent = gallery.querySelectorAll('.gallery-item').length + ' фото';
}

function showStatus(msg, type) {
    const el = document.getElementById('status');
    el.className = 'status ' + type;
    el.textContent = msg;
}
</script>
</body>
</html>
